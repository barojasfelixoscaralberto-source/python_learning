import numpy as np
import pandas as pd

print(np.__version__)
print(pd.__version__)


matriz = np.array([
    [1, 2, 3], # fila 0
    [4, 5, 6], # fila 1
    [7, 8, 9]  # fila 2
# col0 col1 col2
])


print(matriz)
print(matriz.shape) # dimenciones
print(matriz[0]) # toda la fila
print(matriz[1][2]) # posicion (fila, col)

print(matriz.sum()) # suma de todos los elementos
print(matriz.mean()) # promedio de todos los elementos
print(matriz.sum(axis=0)) # suma por columnas
print(matriz.sum(axis=1)) # suma por filas
